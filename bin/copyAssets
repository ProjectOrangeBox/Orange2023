#!/usr/bin/env php
<?php

declare(strict_types=1);

define('__ROOT__', realpath(__DIR__ . '/../'));
chdir(__ROOT__);

require_once __ROOT__ . '/vendor/autoload.php';

/* send config into application */
$container = cli(include __ROOT__ . '/config/config.php');

$console = $container->console;

$console->minimumArguments(1, 'Please include the path to the assets you would like to add as your last option.');

$assetFolder = $console->getLastArgument();

$overwrite = $console->getArgumentExists('-o');

$absPath = realpath(__ROOT__ . '/' . trim($assetFolder, '/'));

if ($absPath === false) {
    $console->stop('Unable to locate "' . $assetFolder . '".');
}

$console->echo('<primary>Using folder "' . $absPath . '".');

// bin folder copy
copyR($absPath, __ROOT__, '/bin', $overwrite);

// htdocs copy
copyR($absPath, __ROOT__, '/htdocs', $overwrite);

// support copy
copyR($absPath, __ROOT__, '/support', $overwrite);

// add var folder
copyR($absPath, __ROOT__, '/var', $overwrite);

// copy configs
copyR($absPath, __ROOT__, '/config', $overwrite);

// merge configs
mergeR($absPath, __ROOT__, '/config');

function mergeR(string $source, string $dest, string $path): void
{
    global $console;

    if (!is_dir($source . $path)) {
        return;
    }

    $comment = '/* merged content below */';
    $endComment = '/* end merged contents */';

    $directory = new RecursiveDirectoryIterator($source . $path, FilesystemIterator::SKIP_DOTS);
    $matches = new RecursiveIteratorIterator($directory);

    foreach ($matches as $file) {
        $from = $file->getPathname();
        $to = $dest . str_replace($source, '', $from);
        $to = str_replace('/@', '/', $to);

        $c1 = substr($file->getFilename(), 0, 1);

        if ($c1 == '@') {
            $console->info('Merge ' . str_replace(__ROOT__,'',$from) . ' into ' . str_replace(__ROOT__,'',$to));

            if (!hasString($to, $comment)) {
                $console->warning('Could not locate "' . $comment . '" skipping file');
            } else {
                if (!hasString($to, $endComment)) {
                    $console->warning('Could not locate "' . $endComment . '" skipping file');
                } else {
                    $mergeContent = file_get_contents($from);
                    $toContent = file_get_contents($to);

                    if (strpos(normalize($toContent), normalize($mergeContent)) !== false) {
                        $console->warning('Seems merged content may already be in destination file. Skipping');
                    } else {
                        file_put_contents($to, putAfter($to, $comment, $mergeContent), LOCK_EX);
                    }
                }
            }
        }
    }
}

function normalize(string $input): string
{
    return preg_replace("/[^a-z0-9]/", '', strtolower($input));
}

function copyR(string $source, string $dest, string $path, bool $overwrite): void
{
    global $console;

    if (!is_dir($source . $path)) {
        return;
    }

    $directory = new RecursiveDirectoryIterator($source . $path, FilesystemIterator::SKIP_DOTS);
    $matches = new RecursiveIteratorIterator($directory);

    foreach ($matches as $file) {
        $from = $file->getPathname();
        $to = $dest . str_replace($source, '', $from);

        $c1 = substr($file->getFilename(), 0, 1);

        if (!in_array($c1, ['.', '@']) && $file->getFilename() != 'readme') {
            $console->info('Copying "' . str_replace(__ROOT__, '', $from) . '" to "' . str_replace(__ROOT__, '', $to) . '".');

            if (file_exists($to)) {
                if (!$overwrite) {
                    $console->warning('"' . str_replace(__ROOT__,'',$to) . '" already exists.');
                } else {
                    $console->warning('Removing "' . str_replace(__ROOT__,'',$to) . '".');
                    unlink($to);
                }
            }

            $path = pathinfo($to);

            if (!file_exists($path['dirname'])) {
                mkdir($path['dirname'], 0777, true);
            }

            if (!copy($from, $to)) {
                $console->stop('Could not copy "' . str_replace(__ROOT__, '', $source) . '"  to "' . str_replace(__ROOT__, '', $to) . '".');
            }
        }
    }
}

function hasString(string $absFilePath, string $string): bool
{
    $found = false;
    $lines = file($absFilePath);

    foreach ($lines as $line) {
        if (trim($line) == $string) {
            $found = true;

            break;
        }
    }

    return $found;
}

function putAfter(string $absFilePath, string $after, string $put): string
{
    $success = false;
    $newFile = '';
    $lines = file($absFilePath);

    foreach ($lines as $line) {
        $newFile .= $line;

        if (trim($line) == $after && $success == false) {
            $newFile .= PHP_EOL;
            $newFile .= $put;
            $newFile .= PHP_EOL;

            $success = true;
        }
    }

    return $newFile;
}

function putBefore(string $absFilePath, string $before, string $put): string
{
    $success = false;
    $newFile = '';
    $lines = file($absFilePath);

    foreach ($lines as $line) {
        if (trim($line) == $before && $success == false) {
            $newFile .= PHP_EOL;
            $newFile .= $put;
            $newFile .= PHP_EOL;

            $success = true;
        }

        $newFile .= $line;
    }

    file_put_contents($absFilePath, $newFile, LOCK_EX);

    return $newFile;
}
